# BI & Operational Data Architecture — Modern / managed-SaaS stack
# Render: d2 --layout elk architecture-modern.d2 architecture-modern.png

direction: right

vars: {
  d2-config: {
    pad: 60
  }
}

# ----------------------- Reusable styles --------------------
classes: {
  tool: {
    style: { fill: "#FFFFFF"; stroke: "#D9DEE3"; stroke-width: 2; border-radius: 10; shadow: true; font-size: 19 }
  }
  store: {
    shape: cylinder
    style: { fill: "#FFFFFF"; stroke: "#B0BEC5"; stroke-width: 2; shadow: true; font-size: 19 }
  }
  zone: {
    style: { stroke-width: 2; border-radius: 16; font-size: 26; bold: true }
  }
  flow: {
    style: { stroke: "#5B6B7B"; stroke-width: 3; font-size: 24; bold: true }
  }
  medallion: {
    style: { stroke: "#90A4AE"; stroke-width: 3; stroke-dash: 4 }
  }
}

title: "BI & Operational Data Architecture — Modern / managed-SaaS stack" {
  near: top-center
  shape: text
  height: 110
  style: { font-size: 40; bold: true; font-color: "#2B3640" }
}

# ----------------- Operational Data Sources -----------------
ods: Operational Data Sources {
  class: zone
  style: { fill: "#ECEFF1"; stroke: "#607D8B" }

  extapis: "External APIs\n(SaaS / REST)" { class: tool; icon: https://cdn.simpleicons.org/openapiinitiative }
  apps: "Apps & Services\n(cloud services)" { class: tool; icon: https://cdn.simpleicons.org/fastapi }
  sourcedbs: "Operational DBs\n(Amazon RDS / Cloud SQL)" {
    class: store
    icon: https://api.iconify.design/logos/aws-rds.svg
    style.stroke: "#527FFF"
  }
}

# --------------------- Cloud Data Platform -----------------------
dlh: "Cloud Data Platform" {
  class: zone
  style: { fill: "#FAFBFC"; stroke: "#90A4AE"; font-size: 22 }

  # ---------- Governance (cross-cutting) ----------
  gov: Governance Layer {
    class: zone
    grid-rows: 1
    style: { fill: "#E8F5E9"; stroke: "#43A047" }
    discovery: "Data Discovery\nAtlan" { class: tool; icon: https://api.iconify.design/mdi/magnify.svg }
    catalog: "Data Catalog\nAtlan" { class: tool; icon: https://api.iconify.design/mdi/book-open-variant.svg }
    lineage: "Data Lineage\nAtlan" { class: tool; icon: https://api.iconify.design/mdi/sitemap.svg }
    rbac: "RBAC\nSnowflake Horizon / IAM" { class: tool; icon: https://api.iconify.design/mdi/shield-lock-outline.svg }
  }

  # ---------- Ingestion ----------
  ingestion: Ingestion Layer {
    class: zone
    style: { fill: "#FFF8E1"; stroke: "#F9A825" }

    batch: "Batch Ingestion\nFivetran + Debezium (CDC)" { class: tool; icon: https://api.iconify.design/mdi/sync.svg }
    stream: "Stream Ingestion\nSnowpipe Streaming" { class: tool; icon: https://cdn.simpleicons.org/snowflake }

    mb: Message Bus {
      class: zone
      style: { fill: "#FFFDF3"; stroke: "#FBC02D"; font-size: 22 }
      topics: "Topics\nConfluent Cloud (Kafka)" {
        class: tool
        shape: queue
        icon: https://cdn.simpleicons.org/apachekafka
      }
      registry: "Schema Registry\nConfluent Schema Registry" { class: tool; icon: https://cdn.simpleicons.org/apacheavro }
    }
  }

  # ---------- Transformation ----------
  transform: Transformation Layer {
    class: zone
    style: { fill: "#FCE4EC"; stroke: "#E53935" }

    streamproc: "Stream Processing\nSnowflake Dynamic Tables" { class: tool; icon: https://cdn.simpleicons.org/snowflake }
    batchproc: "Batch Processing\ndbt Cloud on Snowflake" { class: tool; icon: https://api.iconify.design/logos/dbt-icon.svg }
    orch: "Orchestration\nAstronomer (Airflow)" { class: tool; icon: https://cdn.simpleicons.org/apacheairflow }
    dq: "Data Quality\ndbt tests + Great Expectations" { class: tool; icon: https://api.iconify.design/logos/dbt-icon.svg }

    bronze: "Bronze\n(Snowflake / Iceberg tables)" { class: store; style.stroke: "#CD7F32" }
    silver: "Silver\n(Snowflake)" { class: store; style.stroke: "#9E9E9E" }
    gold: "Gold\n(Snowflake)" { class: store; style.stroke: "#D4AF37" }
    userspace: "User Space\n(sandbox schema)" { class: store; style.stroke: "#607D8B" }

    bronze -> silver -> gold: { class: medallion }
  }

  # ---------- Systems Serving ----------
  systems: Systems Serving Layer {
    class: zone
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }

    specdb: "Specialized DBs\nClickHouse Cloud / Rockset" { class: tool; icon: https://cdn.simpleicons.org/clickhouse }
    federation: "Query Federation\nSnowflake (Iceberg / external)" { class: tool; icon: https://cdn.simpleicons.org/snowflake }
    aggregations: "Aggregations\n& Views" { class: store }
    metrics: "Metrics\n& KPIs" { class: store }
  }

  # ---------- User Serving ----------
  userserving: User Serving Layer {
    class: zone
    style: { fill: "#F3E5F5"; stroke: "#8E24AA" }

    dashboards: "Dashboarding\nLooker / Sigma" { class: tool; icon: https://cdn.simpleicons.org/looker }
    reporting: "Reporting\nTableau" { class: tool; icon: https://api.iconify.design/logos/tableau.svg }
    cache: "Cache\nElastiCache (Redis)" { class: tool; icon: https://cdn.simpleicons.org/redis }
  }
}

# ----------------------- Data Flows -------------------------
ods.apps -> ods.sourcedbs: { class: flow }
ods.sourcedbs -> dlh.ingestion.batch: "1" { class: flow }
ods.apps -> dlh.ingestion.mb.topics: "2" { class: flow }
ods.extapis -> dlh.ingestion.batch: "3" { class: flow }
dlh.ingestion.batch -> dlh.ingestion.mb.topics: "4" { class: flow }
dlh.ingestion.mb.topics -> dlh.ingestion.stream: "5" { class: flow }
dlh.ingestion.mb.topics <-> dlh.transform.streamproc: "6" { class: flow }
dlh.ingestion.stream -> dlh.transform.bronze: "7" { class: flow }
dlh.transform -> dlh.systems: "8" { class: flow }
dlh.systems -> dlh.userserving: "9" { class: flow }
dlh.systems.specdb -> ods.apps: "10 · real-time products" { class: flow }

# Copy to .env and adjust as needed. All values have sensible defaults (see config.py).

# Postgres / TimescaleDB connection (matches docker-compose.yml)
DATABASE_URL=postgresql://crypto:crypto@localhost:15432/crypto

# Optional CoinGecko demo/pro API key. Without it the free public API caps at
# ~30 calls/min, below the 60/min a true 1s cadence needs (see README trade-offs).
# COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx

# Polling / alerting tunables
POLL_INTERVAL_S=1.0
ALERT_WINDOW_S=300
ALERT_THRESHOLD=0.02
ALERT_WARMUP_S=30
ALERT_FILE=alerts.txt
